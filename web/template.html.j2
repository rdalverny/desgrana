<!DOCTYPE html>
<html lang="{{ lang }}" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="author" content="{{ author_url }}">
  <meta name="robots" content="index,follow">
  <link rel="canonical" href="{{ canonical }}">
  <link rel="alternate" hreflang="en" href="{{ alt_en }}">
  <link rel="alternate" hreflang="fr" href="{{ alt_fr }}">
  <link rel="alternate" hreflang="x-default" href="{{ alt_default }}">
  <title>{{ meta.title }}</title>
  <meta name="keywords" content="{{ meta.keywords }}">
  <meta name="description" content="{{ meta.description }}">

  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ og_url }}">
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:title" content="{{ meta.og_title or meta.title }}">
  <meta property="og:description" content="{{ meta.og_description or meta.description }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ meta.og_title or meta.title }}">
  <meta name="twitter:description" content="{{ meta.og_description or meta.description }}">

  <meta property="og:image" content="{{ og_image }}">
  <meta name="twitter:image" content="{{ og_image }}">
  <meta property="og:image:width" content="{{ og_image_w }}">
  <meta property="og:image:height" content="{{ og_image_h }}">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Desgrana",
    "operatingSystem": "macOS 13+, Linux",
    "applicationCategory": "MultimediaApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "{{ meta.jsonld_description }}",
    "url": "{{ canonical }}",
    "inLanguage": "{{ lang }}",
    "downloadUrl": "{{ releases_url }}",
    "softwareVersion": "{{ version }}",
    "license": "https://opensource.org/licenses/MIT",
    "author": { "@type": "Person", "name": "Romain d'Alverny", "url": "https://romaindalverny.com/#romain" }
  }
  </script>

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico">

  <link rel="stylesheet" href="{{ css_href }}">
  <style>
    /* ── Download ── */
    .download-wrap {
      text-align: center;
      margin-top: 1rem;
      margin-bottom: 20px;
    }
    .btn-download {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--accent);
      color: #fff;
      font-family: inherit;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      padding: 13px 28px;
      border-radius: 980px;
      transition: opacity .15s;
    }
    .btn-download:hover { opacity: .82; }
    .btn-download svg { flex-shrink: 0; }
    .download-meta {
      margin-top: 10px;
      font-size: .82rem;
      color: var(--muted);
    }
    .download-meta a { color: var(--muted); }

    /* ── Features grid ── */
    .features {
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px 32px;
    }
    .features li {
      font-size: .93rem;
      padding-left: 18px;
      position: relative;
    }
    .features li::before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--muted);
      font-size: .85rem;
    }
    @media (max-width: 520px) {
      .features { grid-template-columns: 1fr; }
    }
    .video-wrap {
      position: relative;
      display: inline-block;
      border-radius: 12px;
      overflow: hidden;
      margin-top: 1rem;
    }
    .video-wrap::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      box-shadow: inset 0 0 28px rgba(0,0,0,.18);
      pointer-events: none;
    }
    /* ── Consoles table ── */
    dd table {
      border-collapse: collapse;
      margin-top: .35rem;
      font-size: .93rem;
    }
    dd table td {
      padding: .25rem .6rem;
      border-bottom: 1px solid var(--border, #e0e0e0);
    }
    dd table td:first-child {
      border-right: 1px solid var(--border, #e0e0e0);
      padding-right: 1rem;
    }
    dd table tr:last-child td {
      border-bottom: none;
    }
    .video-wrap video {
      display: block;
      max-width: 100%;
      height: auto;
    }
    .section p { margin-bottom: 1rem; }
    h1 { margin-bottom: 2rem; }

    @media (prefers-color-scheme: dark) {
      .btn-download {
        color: #161614;
      }
    }
    /* ── Language switcher ── */
    .breadcrumb .lang-switch { float: right; }
  </style>
</head>
<body>

  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href="/">Rod&rsquo;A</a>
    <span aria-hidden="true">›</span>
    <a href="/atelier/">atelier</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">desgrana</span>
    <a class="lang-switch" href="{{ switch_href }}" hreflang="{{ switch_label | lower }}">{{ switch_label }}</a>
  </nav>

  <header>
    <h1>{{ hero.title_main }}
        <span style="font-size: 80%; font-weight: normal; display: block;">{{ hero.title_sub }}</span></h1>
    <p class="hero">{{ hero.tagline }}</p>

    <div class="video-wrap" style="margin: 1rem auto; max-width: 680px;">
      <video
        src="{{ asset_prefix }}demo.mp4"
        poster="{{ asset_prefix }}demo-poster.jpg"
        muted loop playsinline
        preload="none"
        controls></video>
    </div>
  </header>

  <div class="download-wrap">
    <a class="btn-download" href="{{ dmg_url }}" download>
      <svg width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
        <path d="M8.5 2v9m0 0L5 7.5M8.5 11l3.5-3.5M2 14h13"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"/>
      </svg>
      {{ download.macos_label.format(v=version) }}
    </a>
    <p class="download-meta">
      {{ download.macos_meta.format(date=download_date) }}
    </p>

    <a class="btn-download" href="{{ linux_url }}" style="margin-top: 1.2rem;">
      <svg width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
        <path d="M8.5 2v9m0 0L5 7.5M8.5 11l3.5-3.5M2 14h13"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"/>
      </svg>
      {{ download.linux_label.format(v=version) }}
    </a>
    <p class="download-meta">
      {{ download.linux_meta.format(date=download_date) }}
    </p>

    <p class="download-meta" style="margin-top: 1rem;">{{ download.platforms_note }}</p>
  </div>

  <div class="section">
    <h2>{{ situation.heading }}</h2>
{% for p in situation.paragraphs %}    <p>{{ p }}</p>
{% endfor %}  </div>

  <div class="section">
    <h2>{{ features.heading }}</h2>
    <ul class="features">
{% for f in features['items'] %}      <li>{{ f }}</li>
{% endfor %}    </ul>
  </div>

  <div class="section faq">
    <h2>{{ faq.heading }}</h2>
    <dl>
{% for item in faq['items'] %}      <dt{% if item.id %} id="{{ item.id }}"{% endif %}>{{ item.q }}</dt>
      <dd>{{ item.a_html }}</dd>
{% endfor %}    </dl>
  </div>

  <div class="section changelog" id="changelog">
    <h2>{{ changelog.heading }}</h2>
    <ul>
{% for rel in changelog['items'] %}      <li>
        <span class="v-label">{{ rel.version }}<span class="v-date">{{ rel.date }}</span></span>
        <span class="v-notes">
          {{ rel.notes_html }}
        </span>
      </li>
{% endfor %}    </ul>
  </div>

  <div class="section changelog" id="roadmap">
    <h2>{{ roadmap.heading }}</h2>
{% for p in roadmap.paragraphs %}    <p>{{ p }}</p>
{% endfor %}  </div>

  <footer>
    <p>{{ footer.text }}</p>
  </footer>

</body>
</html>
